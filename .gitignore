# Terraform working directory
**/.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Terraform lock file
.terraform.lock.hcl

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json

# Terraform plan files
*.tfplan
*tfplan*

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI config
.terraformrc
terraform.rc

# Terragrunt
.terragrunt-cache/

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Testing
testing/